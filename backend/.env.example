# ── Base de données ───────────────────────────────────────────────────────────
# URL de connexion Postgres (Neon serverless recommandé — gratuit pour démarrer)
# Créer un projet sur https://neon.tech, copier la "connection string" (mode pooled).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
# URL publique de ce serveur une fois déployé (utilisée par better-auth pour les
# liens de vérification email, et pour restreindre le CORS — cf. ARCHITECTURE.md
# section "CORS")
PUBLIC_BASE_URL=http://localhost:8000
# Origine autorisée à appeler cette API en CORS (scheme de l'app mobile, ex: actio://)
# Laisser vide en dev si tu testes uniquement via Scalar/curl.
ALLOWED_ORIGIN=

# ── Authentification (better-auth) ────────────────────────────────────────────
# Clé secrète utilisée pour signer les sessions — génère une vraie valeur aléatoire :
#   openssl rand -base64 32
BETTER_AUTH_SECRET=changeme-generate-a-real-random-secret

# ── SSO Google ───────────────────────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials. Crée un OAuth Client ID
# PAR PLATEFORME (Web, iOS, Android) — Google donne un ID différent à chacun.
# Liste-les séparés par des virgules, better-auth accepte n'importe lequel.
GOOGLE_CLIENT_ID=xxxxx-web.apps.googleusercontent.com,xxxxx-ios.apps.googleusercontent.com,xxxxx-android.apps.googleusercontent.com
# Le client secret est celui du client Web uniquement (iOS/Android n'en ont pas).
GOOGLE_CLIENT_SECRET=changeme

# ── IA (parsing de tâche par texte ET par voix) ───────────────────────────────
# Clé API OpenRouter — https://openrouter.ai/keys (donne accès à de nombreux
# modèles, dont des modèles GRATUITS, derrière une seule API compatible OpenAI)
OPENROUTER_API_KEY=sk-or-v1-xxxxx
# Modèle texte — gratuit par défaut et compatible tool-calling. Change-le si
# tu veux un modèle payant plus capable (liste : https://openrouter.ai/models,
# filtre "tools" dans supported_parameters).
LLM_MODEL=openai/gpt-oss-20b:free
# Modèle AUDIO — doit accepter l'audio en entrée ET le tool-calling. Le modèle
# par défaut transcrit ET extrait la tâche en un seul appel, gratuitement.
LLM_AUDIO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# ── Paiements (abonnement Pro) ─────────────────────────────────────────────────
# Clé secrète d'API Moneroo (dashboard > Developers > API Keys) — utilisée
# pour APPELER l'API Moneroo (créer un paiement). Couvre l'Afrique.
MONEROO_API_KEY=changeme
# Secret de signature webhook (dashboard > Developers > Webhooks) — utilisé
# pour VÉRIFIER qu'un webhook reçu vient bien de Moneroo (ne JAMAIS faire
# confiance à un webhook non vérifié, cf. ARCHITECTURE.md section "Webhook Moneroo").
MONEROO_WEBHOOK_SECRET=changeme

# LemonSqueezy — pour les paiements carte/PayPal des utilisateurs
# Europe/Amérique (Moneroo ne couvre que l'Afrique, cf. ARCHITECTURE.md
# "Double prestataire de paiement par région"). Laisse vide si tu ne sers pas
# ces régions pour l'instant — tout le monde utilisera Moneroo par défaut.
# LEMONSQUEEZY_API_KEY=
# ID de la boutique — dashboard > Settings > General
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_PRODUCT_ID=
# Une variante par période de facturation, créées dans le dashboard
# LEMONSQUEEZY_VARIANT_ID_MONTHLY=
# LEMONSQUEEZY_VARIANT_ID_YEARLY=
# Secret de signature webhook — Settings > Webhooks
# LEMONSQUEEZY_WEBHOOK_SECRET=

# ── Email (vérification de compte) ────────────────────────────────────────────
# Désactivé par défaut pour démarrer simplement (cf. src/lib/auth.ts). Pour
# activer requireEmailVerification, fournis ces deux variables.
# RESEND_API_KEY — https://resend.com/api-keys
RESEND_API_KEY=
# Adresse d'un domaine vérifié dans ton dashboard Resend, ou
# "onboarding@resend.dev" en test (limité à l'email de ton propre compte Resend).
EMAIL_FROM=

# ── SMS / WhatsApp (alertes Garant) ───────────────────────────────────────────
# Termii (https://termii.com) — une seule API pour SMS et WhatsApp. Laisse
# vide pour désactiver ces deux canaux (ils échouent explicitement, cf.
# lib/termii.ts).
# TERMII_API_KEY=
# Sender ID approuvé dans ton dashboard Termii (3-11 caractères alphanum.)
# TERMII_SENDER_ID=
# Vérifie ta valeur exacte dans le dashboard Termii — pas toujours
# api.ng.termii.com selon le compte/pays.
# TERMII_BASE_URL=https://api.ng.termii.com
