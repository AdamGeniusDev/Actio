# Variables d'environnement CÔTÉ CLIENT — visibles dans le bundle final
# (Expo n'expose que les variables préfixées EXPO_PUBLIC_, c'est volontaire :
# ne mets JAMAIS de secret ici, seulement des valeurs publiques comme une URL
# ou un client ID OAuth, qui sont déjà visibles dans n'importe quel client).

# URL du backend (cf. backend/.env.example) — pendant le dev local, utilise
# l'IP locale de ta machine (pas "localhost", qui ne fonctionne pas depuis un
# appareil/émulateur physique) : ex. http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Client ID Google "Web" (PAS le iOS/Android) — nécessaire pour
# GoogleSignin.configure({ webClientId }), qui sert à obtenir un idToken
# valide côté Google. Même valeur que GOOGLE_CLIENT_ID (la partie "web") côté
# backend.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optionnel — uniquement nécessaire pour iOS native build (cf. app.json,
# plugin @react-native-google-signin/google-signin). Format :
# com.googleusercontent.apps.<id> — trouvable dans le GoogleService-Info.plist
# téléchargé depuis Google Cloud Console pour le client iOS.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
